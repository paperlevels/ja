---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { LoglineForm } from "@/components/loglines/LoglineForm";
import { LoglineCard } from "@/components/loglines/LoglineCard";
import { getLoglines } from "@/lib/data";

const sort = Astro.url.searchParams.get("sort") === "popular" ? "popular" : "newest";
const search = Astro.url.searchParams.get("q") || "";

const loglines = await getLoglines(sort, search);
---

<Layout>
  <div class="mx-auto max-w-2xl px-4 py-12 md:py-16">
    <!-- Hero -->
    <section class="mb-12 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl">
        あなたが欲しいサイトを
        <br class="hidden sm:block" />
        <span class="text-muted-foreground">1行で投稿</span>
      </h1>
      <p class="mt-4 text-base text-muted-foreground sm:text-lg">
        アイデアの需要を、最小限で早期に検証
      </p>
    </section>

    <!-- Post Form -->
    <section class="mb-10">
      <LoglineForm client:load />
    </section>

    <!-- Sort Tabs -->
    <div class="mb-6 flex items-center gap-1 rounded-full bg-secondary p-1 w-fit">
      <a
        href={`?${search ? `q=${encodeURIComponent(search)}&` : ""}sort=popular`}
        class={`inline-flex items-center justify-center rounded-full px-4 py-1.5 text-sm font-medium transition-all ${
          sort === "popular"
            ? "bg-card text-foreground shadow-sm"
            : "text-muted-foreground hover:text-foreground"
        }`}
      >
        人気順
      </a>
      <a
        href={`?${search ? `q=${encodeURIComponent(search)}&` : ""}sort=newest`}
        class={`inline-flex items-center justify-center rounded-full px-4 py-1.5 text-sm font-medium transition-all ${
          sort === "newest"
            ? "bg-card text-foreground shadow-sm"
            : "text-muted-foreground hover:text-foreground"
        }`}
      >
        新着順
      </a>
    </div>

    <!-- List -->
    <div class="flex flex-col gap-3">
      {loglines.length === 0 ? (
        <div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-border py-16 text-center">
          <p class="text-sm text-muted-foreground">
            まだ投稿がありません
          </p>
          <p class="mt-1 text-xs text-muted-foreground/60">
            最初のログラインを投稿してみましょう
          </p>
        </div>
      ) : (
        loglines.map((logline) => (
          <LoglineCard logline={logline} />
        ))
      )}
    </div>
  </div>
</Layout>
