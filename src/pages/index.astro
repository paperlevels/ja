---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { LoglineFeed } from "@/components/loglines/LoglineFeed";
import { getLoglines } from "@/lib/data";

const sort = Astro.url.searchParams.get("sort") === "popular" ? "popular" : "newest";
const search = Astro.url.searchParams.get("q") || "";
const site = Astro.site ?? new URL(Astro.url.origin);

const loglines = await getLoglines(sort, search);

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Paperlevels",
  url: site.toString(),
  description: "1文から始まる物語。ログラインを投稿して、読者の反応を測ろう。",
  potentialAction: {
    "@type": "SearchAction",
    target: `${site.origin}/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: site.toString(),
    },
  ],
};
---

<Layout
  title="Paperlevels - ログラインで需要を測る"
  description="1文から始まる物語。ログラインを投稿して、読者の反応を測ろう。"
  canonicalPath="/"
  jsonLd={[websiteJsonLd, breadcrumbJsonLd]}
>
  <div class="mx-auto max-w-2xl px-4 py-12 md:py-16">
    <!-- Hero -->
    <section class="mb-12 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl">
        あなたが欲しいサイトを
        <br class="hidden sm:block" />
        <span class="text-muted-foreground">1行で投稿</span>
      </h1>
      <p class="mt-4 text-base text-muted-foreground sm:text-lg">
        アイデアの需要を、最小限で早期に検証
      </p>
    </section>

    <LoglineFeed client:load initialLoglines={loglines} sort={sort} search={search} />
  </div>
</Layout>
